# Supabase (erforderlich für die App)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# App (optional, Standard: localhost)
# Basis-Domain ohne Protokoll – u.a. für Kassen-QR: https://{Markt-Subdomain}.{VITE_APP_DOMAIN}/kasse/...
# Beispiel Production: example.com → QR https://angerbogen.example.com/kasse/...
# Vercel: Variable in Production setzen und neu deployen; Anleitung: docs/DEPLOYMENT_DOMAINEN_UND_KASSE.md
VITE_APP_DOMAIN=

# Tutorial / Onboarding: In Production-Build standardmäßig AUS (keine Header-Icons, kein Auto-Start).
# Zum Einschalten auf dem Host: VITE_TUTORIAL_ENABLED=true setzen und neu deployen.
# Lokal mit `npm run dev` immer an.
# VITE_TUTORIAL_ENABLED=true

# Sentry (optional, für Error-Reporting)
# VITE_SENTRY_DSN=
