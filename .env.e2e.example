# E2E-Test-Accounts (Supabase Auth). Kopie als .env.e2e anlegen und Werte eintragen.
# .env.e2e wird von Git ignoriert und nicht committet.
#
# EMPFOHLEN: Test-User über die App (Benutzerverwaltung) anlegen – dann sind Markt,
# Rolle und user_store_access korrekt gesetzt.
#
# Falls User direkt in Supabase angelegt werden:
# - "Add user" → E-Mail + Passwort
# - User Metadata (Raw) muss "personalnummer" enthalten (UNIQUE pro User!):
#   {"personalnummer": "e2e-viewer-1", "role": "viewer"}
# - Ohne personalnummer = "" → zweiter User schlägt mit "Database error" fehl.
# - Super-Admin: Nach Erstellung in profiles.role auf 'super_admin' setzen.
#
# Für die Journey-Tests (viewer, user, admin, super_admin) werden je E-Mail + Passwort benötigt.
# Wenn eine Variable fehlt, wird der zugehörige Journey-Test übersprungen (test.skip).

# Viewer (Rolle: viewer)
E2E_VIEWER_EMAIL=
E2E_VIEWER_PASSWORD=

# User (Rolle: user)
E2E_USER_EMAIL=
E2E_USER_PASSWORD=

# Admin (Rolle: admin – Abteilungsleiter, NICHT super_admin)
# Hier muss ein Konto mit profiles.role = 'admin' stehen (Login → /admin/, Dashboard „Administration“).
# Super-Admin-Zugang gehört in E2E_SUPER_ADMIN_*; für Admin-Journey und Tutorial-@extended ist Super-Admin ungültig.
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=

# Super-Admin (Rolle: super_admin)
# Wenn gesetzt: Alle Super-Admin-Seiten werden durchgetestet (Upload, Layout, Regeln,
# Versionen, Firmen & Märkte, Obst- und Backshop-Seiten).
E2E_SUPER_ADMIN_EMAIL=
E2E_SUPER_ADMIN_PASSWORD=

# Optional: Vollständiger Kiosk-Login (Token + Kasse + Passwort aus Staging) – nicht standardisiert; siehe e2e/kiosk-entrance.spec.ts (ungültiger Token ohne Credentials).

# Optional: Abweichende Base-URL (Standard: http://localhost:5173)
# PLAYWRIGHT_BASE_URL=http://localhost:5173
